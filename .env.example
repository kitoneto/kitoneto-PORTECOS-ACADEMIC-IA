# =============================================================
# PORTECOS ACADEMIC IA — Environment Variables
# Copy this file to .env.local and fill in your values
# =============================================================

# --- App ---
NODE_ENV=development
APP_URL=http://localhost:3000
API_URL=http://localhost:4000

# --- Database (PostgreSQL) ---
DATABASE_URL=postgresql://portecos:password@localhost:5432/portecos_academic
DB_HOST=localhost
DB_PORT=5432
DB_NAME=portecos_academic
DB_USER=portecos
DB_PASSWORD=changeme

# --- Auth (JWT) ---
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=your-refresh-token-secret
REFRESH_TOKEN_EXPIRES_IN=30d

# --- AI (OpenAI / Gemini) ---
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o
GEMINI_API_KEY=your-gemini-api-key
AI_ENGINE_URL=http://localhost:5000

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_KEY=eyJ...
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# --- Email (SMTP) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=noreply@portecosacademic.ao
SMTP_PASSWORD=your-smtp-password
SMTP_FROM="PORTECOS ACADEMIC IA <noreply@portecosacademic.ao>"

# --- WhatsApp (Twilio/WABA) ---
WHATSAPP_API_URL=https://api.twilio.com/2010-04-01
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
WHATSAPP_FROM=whatsapp:+244XXXXXXXXX

# --- Payments (Angolan) ---
MULTICAIXA_API_URL=https://api.multicaixaexpress.ao
MULTICAIXA_API_KEY=your-multicaixa-key
UNITEL_MONEY_API_URL=https://api.unitelmoney.ao
UNITEL_MONEY_API_KEY=your-unitel-money-key
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# --- Storage (S3-compatible) ---
STORAGE_ENDPOINT=https://s3.amazonaws.com
STORAGE_BUCKET=portecos-academic
STORAGE_ACCESS_KEY=your-access-key
STORAGE_SECRET_KEY=your-secret-key
STORAGE_REGION=af-south-1

# --- Redis (Cache/Sessions) ---
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# --- Monitoring ---
SENTRY_DSN=https://xxx@o000.ingest.sentry.io/0000

# --- Feature Flags ---
ENABLE_PAYMENTS=false
ENABLE_CERTIFICATES=true
ENABLE_AI_TUTOR=true

# --- MES Compliance ---
# No additional vars needed — uses Supabase connection above
# Human reviewers are managed via the admin panel
